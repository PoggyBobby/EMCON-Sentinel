# ATAK SDK is gov-distributed, very large, and not redistributable: keep out of repo
sdk/

# Reference plugins (cloned for study, not part of our source)
tools/reference/

# Local-only build/IDE state
**/local.properties
**/build/
**/.gradle/
**/out/
**/captures/
**/.cxx/
**/.kotlin/
**/release/
**/.idea/
*.iml

# Signing — never commit keystores
*.keystore
*.jks
*.p12

# OS noise
.DS_Store
Thumbs.db
*.swp
*~

# Built APKs (we only attach the signed release to GitHub Releases)
*.apk

# Logs
*.log

# Python build artifacts (tools/ sidecar scripts)
__pycache__/
*.pyc

# Scratch
scratch/

# Screenshots and demo videos — large binaries, not committed.
# (Hosted on GitHub Releases or in a separate media branch if needed.)
docs/screenshots/
docs/*.mp4
docs/*.mov
docs/*.webm
*.mp4
*.mov
