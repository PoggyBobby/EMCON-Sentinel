<?xml version="1.0" encoding="utf-8"?>
<!-- Radio tab content. Vertically scrollable list of radio cards (instead of
     a 2-column grid which gets cramped on a narrow phone). Each card is built
     dynamically by TabRadio.java. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/radio_card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp" />

</ScrollView>
