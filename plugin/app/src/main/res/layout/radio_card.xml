<?xml version="1.0" encoding="utf-8"?>
<!-- Single radio card. TabRadio inflates one of these per RadioProfile and
     swaps the title/subtitle/checkmark on each card. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="6dp"
    android:background="#FF1A1A1A"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/radio_card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/radio_card_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFAAAAAA"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/radio_card_check"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●"
        android:textColor="#FF2ECC40"
        android:textSize="22sp"
        android:visibility="invisible"
        android:layout_marginStart="8dp" />

</LinearLayout>
