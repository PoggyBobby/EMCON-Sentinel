<?xml version="1.0" encoding="utf-8"?>
<!-- Always-visible strip pinned to the top of the MapView. Shows: mini dial,
     plain-English status, top threat, and a math icon (judge bait). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:orientation="horizontal"
    android:background="#CC000000"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="6dp"
    android:elevation="6dp">

    <com.emconsentinel.ui.MiniRiskRing
        android:id="@+id/hud_mini_ring"
        android:layout_width="28dp"
        android:layout_height="28dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/hud_status_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAFE"
            android:textColor="#FF2ECC40"
            android:textStyle="bold"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/hud_threat_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No active threats"
            android:textColor="#FFAAAAAA"
            android:textSize="10sp"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <Button
        android:id="@+id/hud_math_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="∑"
        android:textSize="16sp"
        android:textColor="#FFFFFFFF"
        android:background="#22FFFFFF"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:contentDescription="Show propagation math" />

</LinearLayout>
