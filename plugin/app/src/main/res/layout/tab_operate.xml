<?xml version="1.0" encoding="utf-8"?>
<!-- Operate tab. One big START/STOP KEYING button + status lines. Power-user
     toggles (C2 link drives keying, propagation engine details) hidden behind
     a "▾ More" disclosure. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <Button
            android:id="@+id/operate_keying_btn"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="START KEYING"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="#FF2ECC40" />

        <Button
            android:id="@+id/operate_surv_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Pre-mission survivability check"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:padding="10dp"
            android:layout_marginTop="6dp"
            android:background="#FF1F4F8F" />

        <TextView
            android:id="@+id/operate_status_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idle. Press START KEYING to begin emitting."
            android:textColor="#FFCCCCCC"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF333333"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/operate_bands_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Active bands"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/operate_bands_help"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toggle off bands you can spare to reduce signature."
            android:textColor="#FF888888"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/operate_bands_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF333333"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="C2 telemetry link"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/operate_c2_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="C2 bridge offline. Run tools/c2_bridge.py to observe real RF."
            android:textColor="#FF888888"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/operate_more_disclosure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▾ More options"
            android:textColor="#FF66AAFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:id="@+id/operate_more_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#FF111111"
            android:padding="10dp">

            <CheckBox
                android:id="@+id/operate_use_c2_for_keying"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use C2 link to drive keying detection (overrides manual button)"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                android:buttonTint="#FFFFFFFF" />

            <TextView
                android:id="@+id/operate_demo_speed_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Demo speed: 1× (long-press dial in HUD to toggle 10×)"
                android:textColor="#FFAAAAAA"
                android:textSize="11sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Propagation: free-space (Friis). Configure CloudRF in settings for terrain-aware modeling."
                android:textColor="#FFAAAAAA"
                android:textSize="11sp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
