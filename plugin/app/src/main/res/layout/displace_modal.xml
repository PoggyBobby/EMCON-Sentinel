<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen DISPLACE modal. Slides up over the map when composite risk
     crosses 0.5. Shows the threat severity, top-3 displacement candidates,
     and a Cancel button. Tap a candidate to drop a Route to that location. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8000000"
    android:elevation="20dp"
    android:padding="20dp">

    <TextView
        android:id="@+id/displace_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MOVE NOW"
        android:textColor="#FFFF1F1F"
        android:textStyle="bold"
        android:textSize="32sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/displace_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Composite risk 0.72 — adversary fix imminent"
        android:textColor="#FFCCCCCC"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Top displacement candidates"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/displace_candidates_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <Button
        android:id="@+id/displace_cancel_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel — accept risk"
        android:textColor="#FFCCCCCC"
        android:padding="14dp"
        android:layout_marginTop="14dp"
        android:background="#FF2A2A2A" />

</LinearLayout>
