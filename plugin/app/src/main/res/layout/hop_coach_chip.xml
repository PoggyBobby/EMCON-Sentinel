<?xml version="1.0" encoding="utf-8"?>
<!-- Hop-coach recommendation chip pinned just below the TopHudStrip. Semi-
     transparent dark pill, 12sp text, dismiss "×" button. Tapping the body
     jumps to TabOperate with the suggested band's switch highlighted. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hop_chip_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#CC102030"
    android:paddingStart="12dp"
    android:paddingEnd="6dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:elevation="6dp">

    <TextView
        android:id="@+id/hop_chip_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quieter: ..."
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:maxWidth="320dp" />

    <Button
        android:id="@+id/hop_chip_dismiss"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="×"
        android:textSize="16sp"
        android:textColor="#FFCCCCCC"
        android:background="#22FFFFFF"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:layout_marginStart="8dp"
        android:contentDescription="Dismiss recommendation" />

</LinearLayout>
