<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMCON Sentinel"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Real-time DF-risk dashboard. Tracks operator RF emissions and adversary direction-finding capability; recommends displacement when stay-time crosses risk threshold."
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Operator radio profile"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <Spinner
            android:id="@+id/radio_profile_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adversary DF assets on map"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/placed_assets_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(none placed)"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/adversary_picker_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/add_asset_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Add asset (tap map)" />

            <Button
                android:id="@+id/clear_assets_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Clear" />
        </LinearLayout>

        <Button
            android:id="@+id/load_demo_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load demo scenario"
            android:layout_marginBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/keying_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="START KEYING"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/keying_status_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/about_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About / OSINT sources" />

    </LinearLayout>
</ScrollView>
